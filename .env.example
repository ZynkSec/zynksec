# Zynksec environment — copy to .env for local dev.
# SECURITY:
#   - Real secrets NEVER go in this file.  Use `changeme-local-only` or
#     `please-generate-a-32-byte-base64-value` as placeholders.
#   - `.env` is gitignored.  Gitleaks scans every commit for patterns
#     that look like real credentials.
# Config surface defined in docs/04_phase0_scaffolding.md §0.8.

# ---------- Core ----------
ZYNKSEC_ENV=dev
ZYNKSEC_LOG_LEVEL=INFO
# JSON-per-line is the default; flip to `console` for human-readable
# coloured output in local dev.  Production MUST stay on `json`.
ZYNKSEC_LOG_FORMAT=json
ZYNKSEC_API_HOST=0.0.0.0
ZYNKSEC_API_PORT=8000

# ---------- PostgreSQL ----------
POSTGRES_USER=zynksec
POSTGRES_PASSWORD=changeme-local-only
POSTGRES_DB=zynksec
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://zynksec:changeme-local-only@postgres:5432/zynksec

# ---------- Redis / Celery ----------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- ZAP ----------
# Phase 2 Sprint 3: multi-instance ZAP fan-out.  Each ``worker{i}``
# container points at ``zap{i}`` via ZAP_API_URL set in compose; the
# value below is the worker1 default (also what a script running
# outside compose would use to reach the first instance).
# ZAP_INSTANCE_COUNT is the source of truth for "how many ZAP+worker
# pairs exist"; the API uses it to round-robin scan-group children
# across the per-ZAP queues.  Bumping it requires adding matching
# zap{i} + worker{i} services in docker-compose.yml — there's no
# hidden auto-discovery.
ZAP_INSTANCE_COUNT=2
ZAP_API_URL=http://zap1:8090
ZAP_API_KEY=changeme-local-only
ZAP_DEFAULT_PROFILE=baseline

# ---------- Mailpit (dev only) ----------
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=zynksec@localhost

# ---------- GlitchTip observability (opt-in: --profile obs) ----------
# Internal credentials for GlitchTip's own postgres.  Only reachable
# inside zynksec-core; not published to host.
GLITCHTIP_POSTGRES_USER=glitchtip
GLITCHTIP_POSTGRES_PASSWORD=changeme-local-only
GLITCHTIP_POSTGRES_DB=glitchtip
# Django SECRET_KEY for the GlitchTip app — rotate if this stack were
# ever exposed beyond localhost.  Phase 0 is dev-only.
GLITCHTIP_SECRET_KEY=please-generate-a-32-byte-base64-value
# SENTRY_DSN is the api + worker's Sentry SDK target.  Left empty by
# default so the SDK no-ops (Week-4 commit 4).  After running
# `--profile obs`, follow README §"Set up error tracking" to create a
# superuser + project in GlitchTip's UI (http://localhost:8001) and
# paste the project DSN here; then restart api + worker.  Both forms
# are accepted — SENTRY_DSN is the primary name; GLITCHTIP_DSN is a
# back-compat alias.
SENTRY_DSN=
GLITCHTIP_DSN=

# ---------- App ----------
APP_SECRET_KEY=please-generate-a-32-byte-base64-value
