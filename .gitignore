# ============================================================
# Zynksec .gitignore
# Covers: Python backend, Next.js/pnpm frontend, Docker,
# editors, OS files, env/secrets, logs, build artifacts.
# ============================================================

# ---------- Secrets & environment ----------
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
MANIFEST

# Virtualenvs
.venv/
venv/
env/
ENV/

# Poetry (unused — Zynksec uses uv; keep ignored in case a contributor runs Poetry by habit)
poetry.lock

# pip
pip-log.txt
pip-delete-this-directory.txt

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Celery
celerybeat-schedule
celerybeat.pid

# Alembic local overrides
alembic.ini.local

# ---------- Node / pnpm / Next.js ----------
node_modules/
.pnpm-store/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Next.js
.next/
out/
next-env.d.ts

# Build caches
.turbo/
.vite/
.webpack/

# Build outputs
build/
dist/

# Package logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# TypeScript
*.tsbuildinfo

# ---------- Docker ----------
docker-compose.override.yml
.docker/
*.local.yml

# ---------- Databases & local data ----------
*.sqlite
*.sqlite3
*.db
data/
.pgdata/
pgdata/

# ---------- Editor / IDE ----------
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.iml
*.swp
*.swo
*~
.cursor/

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- Logs ----------
logs/
*.log

# ---------- Zynksec-specific ----------
# Local scan outputs (reports, evidence dumps, HTTP traces)
scan-output/
.zap/
.zap_session/
zap_session/

# Local target-lab state
target-lab/.local/

# Generated docs
site/
_site/

# Local AI / tooling caches
.claude/
.anthropic/
